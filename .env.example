# Copy to .env locally (never commit .env). On Render: add the same keys in Environment.

# =============================================================================
# DATABASE_URL (MySQL)
# =============================================================================
# The app calls https://kidora-api.onrender.com — rows appear in whatever DB this URL points to.
# If you inspect Railway MySQL but Render uses another DATABASE_URL, safety_search_alerts stays empty there.
# Fix: set Render's DATABASE_URL to the same MySQL connection string as Railway (public proxy URL if needed).

# =============================================================================
# Kidora safety emails FROM kidoraapp06@gmail.com (Gmail + App Password)
# =============================================================================
# 1. Google account: https://myaccount.google.com/ (sign in as kidoraapp06@gmail.com)
# 2. Security → turn on 2-Step Verification
# 3. Security → App passwords → create (e.g. "Kidora Render") → copy 16 characters
# 4. Paste that as SMTP_PASS below (NOT your normal Gmail password)
# 5. On Render set EMAIL_PROVIDER=gmail so Gmail is used even if other API keys exist

EMAIL_PROVIDER=gmail

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=kidoraapp06@gmail.com
SMTP_PASS=paste-16-char-app-password-here
SMTP_FROM=kidoraapp06@gmail.com

# Parents receive mail at users.email from your DB; the "From" line is:
#   Kidora <kidoraapp06@gmail.com>

# =============================================================================
# Optional: other providers (leave EMAIL_PROVIDER=gmail and do not set these)
# =============================================================================
# RESEND_API_KEY=
# SENDGRID_API_KEY=
# USE_FIRESTORE_MAIL=1
